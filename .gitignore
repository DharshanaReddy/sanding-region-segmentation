# Python
__pycache__/
*.pyc
.venv/
*.egg-info/
build/
dist/

# Data / artifacts (large, regenerable — never commit)
data_gen/output/
data_gen/blender_cache/
*.hdf5
*.exr
training/runs/
training/checkpoints/
*.pt
# Exported/quantized models (ONNX/.data/OpenVINO IR/TensorRT engine) all land
# here — scoped to this directory rather than blanket *.onnx/*.xml/etc.
# extension rules, which would otherwise also match legitimate files
# elsewhere in the repo (e.g. ROS2 package.xml).
optimization/exported/
# onnxruntime's quant_pre_process (shape inference) writes this to the
# current working directory regardless of where the model output goes.
sym_shape_infer_temp.onnx

# Notebook checkpoints
.ipynb_checkpoints/

# ROS2 build artifacts
ros2_ws/build/
ros2_ws/install/
ros2_ws/log/

# Your real photos/masks are yours, not the repo's — keep the placeholder READMEs only.
evaluation/real_photos/*
evaluation/real_masks/*
!evaluation/real_photos/README.md
!evaluation/real_masks/README.md

# OS / editor
.DS_Store
.vscode/
.idea/

# Keep smoke-test fixtures despite the patterns above
!tests/fixtures/**
